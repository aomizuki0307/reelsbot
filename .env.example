# LLM Provider: anthropic or openai
LLM_PROVIDER=openai

# OpenAI Settings (primary)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5-mini

# Anthropic Settings (alternative)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Video Settings
DEFAULT_A_DURATION_MIN=8
DEFAULT_A_DURATION_MAX=12
DEFAULT_E_DURATION_MIN=10
DEFAULT_E_DURATION_MAX=14

# Safety Settings
POLICY_MAX_RETRY=3

# A/E Mix Ratio
DEFAULT_A_RATIO=70
DEFAULT_E_RATIO=30

# Paths
OUTPUTS_DIR=outputs
LOGS_DIR=logs
BLOCKED_TERMS_PATH=policies/blocked_terms.txt

# ffmpeg (full path recommended, or 'ffmpeg' if in PATH)
# After running scripts/install_ffmpeg.ps1, use:
FFMPEG_PATH=C:/ffmpeg/bin/ffmpeg.exe
# Or if ffmpeg is in your PATH:
# FFMPEG_PATH=ffmpeg

# Future: Meta Graph API (not used in MVP)
META_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
